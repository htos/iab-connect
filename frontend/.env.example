# IAB Connect — frontend environment-variable template
#
# Copy this file to frontend/.env.local (gitignored) and fill in values for local development.
#
# Next.js configuration precedence (later overrides earlier):
#   .env  <  .env.development | .env.production  <  .env.local  <  runtime process.env
#
# IMPORTANT: variables prefixed with `NEXT_PUBLIC_` are inlined into the static client bundle
# at `next build` time. They are visible to any browser and CANNOT be changed at runtime —
# any URL change requires a frontend rebuild. Sensitive secrets must NOT carry NEXT_PUBLIC_.
#
# Placeholder convention: real secrets NEVER live in this file. Use `__set_in_environment__`
# so that automated secret scanners do not flag this file with false positives once the
# repository is public.

# === API wiring ===
# Required: backend API base URL. Read across ~25 client/server modules (lib/api/*.ts,
# middleware.ts, page route handlers). NEXT_PUBLIC_ → build-time-constant — rebuild required after change.
NEXT_PUBLIC_API_URL=http://localhost:5000

# === NextAuth.js session ===
# Required: canonical URL where this Next.js app is reached. Used by NextAuth callback handling.
NEXTAUTH_URL=http://localhost:3000
# Required: HMAC secret for NextAuth JWT signing. Minimum 32 random chars; rotate carefully
# (rotating invalidates active sessions). Read at middleware.ts:88.
NEXTAUTH_SECRET=__set_in_environment_min_32_chars__

# === Keycloak OIDC (server-side, used by NextAuth) ===
# Required: Keycloak client ID for the frontend. Read at app/api/auth/[...nextauth]/route.ts:62,96.
KEYCLOAK_CLIENT_ID=iabconnect-frontend
# Required: Keycloak client secret for the frontend. Read at app/api/auth/[...nextauth]/route.ts:63,97.
KEYCLOAK_CLIENT_SECRET=__set_in_environment__
# Required: Keycloak realm issuer URL. Read at app/api/auth/[...nextauth]/route.ts:57,98.
# IMPORTANT: This value MUST stay byte-identical to NEXT_PUBLIC_KEYCLOAK_ISSUER below
# (server-side validation here, client-side logout deep-link from the public var). Rotating
# the realm name on one but not the other breaks logout / password reset silently.
KEYCLOAK_ISSUER=http://localhost:8080/realms/iabconnect

# === Keycloak client-side links (password reset, logout) ===
# Required: Keycloak base URL (without realm path). Used by app/login/page.tsx:154 to build the
# password-reset deep link. NEXT_PUBLIC_ → build-time-constant — rebuild required after change.
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
# Required: Keycloak realm name. Used by app/login/page.tsx:154 to build the password-reset deep link.
# NEXT_PUBLIC_ → build-time-constant — rebuild required after change.
NEXT_PUBLIC_KEYCLOAK_REALM=iabconnect
# Required: Keycloak client ID for the frontend (mirrors KEYCLOAK_CLIENT_ID, but exposed to
# the browser for the password-reset link). NEXT_PUBLIC_ → build-time-constant — rebuild required after change.
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=iabconnect-frontend
# Required: Keycloak realm issuer URL exposed to the browser for the logout redirect.
# Read at lib/auth.ts:135. NEXT_PUBLIC_ → build-time-constant — rebuild required after change.
NEXT_PUBLIC_KEYCLOAK_ISSUER=http://localhost:8080/realms/iabconnect

# === Beta + OSS build-time vars (E11/E20 wiring) ===
# Optional (empty in Dev, set to `beta` in Beta): triggers the persistent orange BETA banner
# (E11-S2 / E18-S3). NEXT_PUBLIC_ → build-time-constant — rebuild required after change.
NEXT_PUBLIC_ENV_LABEL=
# Optional: hostname of the document-storage CDN/proxy for next/image remotePatterns.
# Dev default localhost:9000 (RustFS); Beta replaces with Railway-assigned host (E12-S2 build-arg).
# Consumed by next.config.ts images.remotePatterns. NEXT_PUBLIC_ → build-time-constant — rebuild required after change.
NEXT_PUBLIC_DOCUMENT_HOST=localhost:9000
# Optional: upstream source-code URL shown by the license footer (E20-S4) for AGPL §13 disclosure.
# Default points to the canonical repository; forks should override to their own URL.
# NEXT_PUBLIC_ → build-time-constant — rebuild required after change.
NEXT_PUBLIC_SOURCE_URL=https://github.com/htos/iab-connect
# Optional: feedback URL used by the BETA banner (E11-S2). If unset, the banner falls
# back to `NEXT_PUBLIC_SOURCE_URL + /issues/new?template=beta-feedback.md` so forks
# direct testers to their own issue tracker. Override when E18-S4 lands a dedicated
# feedback channel (Discord webhook, Mailtrap address, support form).
# NEXT_PUBLIC_ → build-time-constant — rebuild required after change.
NEXT_PUBLIC_FEEDBACK_URL=
