{
  "realm": "iabconnect",
  "enabled": true,
  "displayName": "IAB Connect",
  "loginTheme": "keycloak",
  "sslRequired": "external",
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "rememberMe": true,
  "verifyEmail": true,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 5,
  "eventsListeners": ["jboss-logging", "disable-new-users"],
  "eventsEnabled": true,
  "enabledEventTypes": ["REGISTER"],
  "defaultRoles": ["member"],
  "smtpServer": {
    "replyToDisplayName": "IAB Connect",
    "starttls": "false",
    "auth": "false",
    "envelopeFrom": "",
    "ssl": "false",
    "password": "",
    "port": "1025",
    "host": "mailhog",
    "replyTo": "noreply@iabconnect.ch",
    "from": "noreply@iabconnect.ch",
    "fromDisplayName": "IAB Connect",
    "user": ""
  },
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Administrator mit vollen Rechten"
      },
      {
        "name": "vorstand",
        "description": "Vorstandsmitglied"
      },
      {
        "name": "member",
        "description": "Reguläres Mitglied"
      }
    ]
  },
  "groups": [
    {
      "name": "Vorstand",
      "realmRoles": ["vorstand", "member"]
    },
    {
      "name": "Mitglieder",
      "realmRoles": ["member"]
    }
  ],
  "clients": [
    {
      "clientId": "iabconnect-admin",
      "name": "IAB Connect Admin Service",
      "enabled": true,
      "publicClient": false,
      "secret": "admin-service-secret-2026",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "fullScopeAllowed": true,
      "defaultClientScopes": ["web-origins", "acr", "roles", "profile", "email"],
      "optionalClientScopes": ["address", "phone", "offline_access", "microprofile-jwt"]
    },
    {
      "clientId": "iabconnect-api",
      "name": "IAB Connect API",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false
    },
    {
      "clientId": "iabconnect-frontend",
      "name": "IAB Connect Frontend",
      "enabled": true,
      "publicClient": false,
      "secret": "frontend-dev-secret-2026",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:3000/*",
        "https://iabconnect.ch/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "https://iabconnect.ch"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    }
  ],
  "users": [
    {
      "username": "admin@iabconnect.ch",
