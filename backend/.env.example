# IAB Connect — backend environment-variable template
#
# Copy this file to backend/.env (gitignored) and fill in values for local development,
# or set the variables on your deployment target (Railway, Docker, systemd, etc.).
#
# .NET configuration precedence (later overrides earlier):
#   appsettings.json  <  appsettings.{ASPNETCORE_ENVIRONMENT}.json  <  environment variables  <  command-line args
#
# Nested-key syntax: use `__` (two underscores) as the separator. POSIX shells and Windows
# env vars do not allow `:` in variable names, so .NET reads `__` from environment variables
# and maps it internally to `:` for the nested-key lookup. `Keycloak__ClientSecret` here ↔
# `"Keycloak": { "ClientSecret": "..." }` in appsettings.json.
#
# Placeholder convention: real secrets NEVER live in this file. Use `__set_in_environment__`
# (with annotations like `__min_32_chars__` for length-sensitive secrets) so that automated
# secret scanners (GitHub built-in, TruffleHog, gitleaks) do not flag this file with false
# positives once the repository is public.

# === Application ===
# Required: ASP.NET Core environment name. One of: Development, Beta, Production, Testing.
ASPNETCORE_ENVIRONMENT=Development
# Required: URLs Kestrel binds to. Use http://+:8080 in container deployments (E12-S1).
ASPNETCORE_URLS=http://+:5000

# === Database ===
# Required: PostgreSQL connection string for the application database. .NET reads this via
# IConfiguration.GetConnectionString("DefaultConnection") (Infrastructure/DependencyInjection.cs:53).
ConnectionStrings__DefaultConnection=__set_in_environment__
# Optional (default: true): toggle EF Core migrations on startup. Set to false in Production
# to apply migrations manually (introduced by SCP-2026-05-15 ADR-015 / consumed by E15-S2).
Database__AutoMigrate=true

# === Identity (Keycloak) ===
# Required: Keycloak realm authority URL for OIDC validation. Read at Api/DependencyInjection.cs:121.
Keycloak__Authority=__set_in_environment__
# Required: Keycloak client ID for the API. Read at Api/DependencyInjection.cs:122.
Keycloak__ClientId=iabconnect-api
# Required: Keycloak client secret for the API. Read at Api/DependencyInjection.cs:123.
Keycloak__ClientSecret=__set_in_environment__
# Optional: Keycloak Admin API base URL (used by the admin SPI client for user provisioning).
# Read at Infrastructure/Identity/KeycloakAdminService.cs:58.
KeycloakAdmin__BaseUrl=__set_in_environment__
# Optional: Keycloak realm name for the admin client.
KeycloakAdmin__Realm=iabconnect
# Optional: admin client ID for the Keycloak Admin API.
KeycloakAdmin__ClientId=iabconnect-admin
# Optional: admin client secret for the Keycloak Admin API.
KeycloakAdmin__ClientSecret=__set_in_environment__
# Required (production): server-side HMAC pepper for calendar-subscription-token hashing.
# Leave empty for plain SHA-256 (local dev / CI default). Production & staging MUST set this
# BEFORE the HmacPepperCalendarSubscriptionTokens migration runs. Minimum 32 chars; strong random.
# Mirrors the guidance in appsettings.json:42 (_comment_CalendarTokenPepper).
Auth__CalendarTokenPepper=__set_in_environment_min_32_chars__

# === Frontend wiring ===
# Required: CORS allowlist origin for the frontend. Read at Api/DependencyInjection.cs:94
# and used by EmailCampaignJobService.cs:96 for outbound email link generation.
Frontend__BaseUrl=http://localhost:3000

# === Object storage (RustFS / S3-compatible) ===
# Required (production): S3-compatible storage endpoint for member documents.
# Read at Infrastructure/DependencyInjection.cs:258-259.
DocumentStorage__ServiceUrl=__set_in_environment__
# Required (production): S3 access key.
DocumentStorage__AccessKey=__set_in_environment__
# Required (production): S3 secret key.
DocumentStorage__SecretKey=__set_in_environment__
# Required (production): bucket name. Default `iabconnect-documents` is dev-only.
DocumentStorage__BucketName=__set_in_environment__
# Optional (default: false): use HTTPS to reach the storage endpoint. Set true in production.
DocumentStorage__UseHttps=false

# === Mail (Mailtrap sandbox in Beta — see ADR-018) ===
# Required (production): SMTP host. Beta uses Mailtrap sandbox; Production uses the chosen
# transactional provider (Brevo/Postmark/SES/Postal). Read at Infrastructure/DependencyInjection.cs:196.
Smtp__Host=__set_in_environment__
# Required (production): SMTP port. 587 (STARTTLS), 465 (TLS), 25 (plain — outbound blocked on most clouds).
Smtp__Port=587
# Required (production): enable SSL/TLS for the SMTP connection.
Smtp__EnableSsl=true
# Required (production): SMTP username.
Smtp__Username=__set_in_environment__
# Required (production): SMTP password.
Smtp__Password=__set_in_environment__
# Required (production): the From: address for outbound mail.
Smtp__FromEmail=noreply@example.org
# Required (production): the From: display name for outbound mail.
Smtp__FromName=IAB Connect
# Optional: dedicated HMAC secret for unsubscribe-token signing. Falls back to Smtp__FromEmail
# when unset (Infrastructure/Email/UnsubscribeTokenService.cs:18-19). Set explicitly in production.
Email__UnsubscribeSecret=__set_in_environment__

# === Branding (white-label per REQ-086 / E9) ===
# Optional: API title shown in OpenAPI/Swagger metadata. Read at Api/DependencyInjection.cs:56.
Branding__ApiTitle=IAB Connect API
# Optional: API description shown in OpenAPI/Swagger metadata. Read at Api/DependencyInjection.cs:58.
Branding__ApiDescription=Member management and communication platform.
# Optional: upstream source-code URL for AGPL §13 disclosure. Default points to the canonical
# repository; forks should override to their own URL. Consumed by /about endpoint (E20-S3).
Branding__SourceUrl=https://github.com/htos/iab-connect

# === Invoicing ===
# Optional: organization name shown on invoices and Swiss QR-bills.
InvoiceSettings__OrganizationName=Your Organization
# Optional: organization postal address shown on invoices.
InvoiceSettings__OrganizationAddress=Musterstrasse 1, 8000 Zürich
# Optional: organization contact email shown on invoices.
InvoiceSettings__OrganizationEmail=info@example.org
# Optional: payment instructions paragraph shown on invoices.
InvoiceSettings__PaymentInstructions=Please transfer the amount to our bank account.
# Optional: invoice currency. CHF is the default for Swiss deployments.
InvoiceSettings__Currency=CHF
# Optional: default payment term in days.
InvoiceSettings__DefaultPaymentTermDays=30

# === Background jobs (Hangfire) ===
# Optional (default: /hangfire): dashboard route prefix from appsettings.json:55-57. The dashboard
# is registered only when ASPNETCORE_ENVIRONMENT=Development; Beta and Production do not expose it.
Hangfire__DashboardPath=/hangfire

# === Features ===
# Optional: enable Swiss e-invoice (eBill) export. Read at Endpoints/InvoiceEndpoints.cs:242.
Features__EInvoiceExport=true

# === Operations ===
# Optional (default: true; set to false in appsettings.Beta.json per ADR-020): toggle the
# RetentionEnforcementJob registration. False prevents retention-driven deletion of tester
# data while retention defaults are not yet final per deployment. Consumed by E11-S2.
RetentionEnforcement__Enabled=true
# Optional: filesystem directory for local pg_dump backup output. Read at
# Infrastructure/Backup/PostgresBackupService.cs:32. Containerized deployments typically use
# a mounted volume path.
Backup__Directory=__set_in_environment__
# Optional: docker container name running PostgreSQL (used by Docker-based backup strategy).
# Read at Infrastructure/Backup/PostgresBackupService.cs:34.
Backup__DockerContainer=__set_in_environment__
# Required (production): symmetric encryption key for gzipped pg_dump output (ADR-019).
# Minimum 32 bytes base64-encoded; stored separately from database credentials (Railway Variable).
Backup__EncryptionKey=__set_in_environment_base64_32_bytes__
