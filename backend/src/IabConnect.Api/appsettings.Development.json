{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.AspNetCore.Authentication": "Debug",
      "Microsoft.AspNetCore.Authentication.JwtBearer": "Debug",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console"],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore.Authentication": "Debug",
        "Microsoft.AspNetCore.Authentication.JwtBearer": "Debug",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/iabconnect-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] [{CorrelationId}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5433;Database=iabconnect;Username=postgres;Password=postgres"
  },
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/iabconnect",
    "ClientId": "iabconnect-api",
    "ClientSecret": "dev-secret-change-me"
  },
  "KeycloakAdmin": {
    "BaseUrl": "http://localhost:8080",
    "Realm": "iabconnect",
    "ClientId": "iabconnect-admin",
    "ClientSecret": "dev-admin-secret-change-me"
  },
  "Smtp": {
    "Host": "localhost",
    "Port": 1025,
    "EnableSsl": false,
    "Username": null,
    "Password": null,
    "FromEmail": "noreply@example.org",
    "FromName": "Organization"
  },
  "Features": {
    "EInvoiceExport": true
  },
  "DocumentStorage": {
    "ServiceUrl": "http://localhost:9000",
    "AccessKey": "rustfsadmin",
    "SecretKey": "rustfsadmin",
    "BucketName": "iabconnect-documents",
    "UseHttps": false
  }
}
