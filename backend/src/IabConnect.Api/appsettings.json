{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": ["FromLogContext"],
    "WriteTo": [{ "Name": "Console" }]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5433;Database=iabconnect;Username=postgres;Password=postgres"
  },
  "Database": {
    "AutoMigrate": true
  },
  "Keycloak": {
    "Authority": "",
    "ClientId": "iabconnect-api",
    "ClientSecret": ""
  },
  "Auth": {
    "_comment_CalendarTokenPepper": "REQ-025 (R3-H-S5-3): server-side secret that HMAC-keys the calendar-subscription-token hash. Leave empty for plain SHA-256 (local dev / CI default). Production & staging set Auth__CalendarTokenPepper via the environment BEFORE the HmacPepperCalendarSubscriptionTokens migration runs.",
    "CalendarTokenPepper": ""
  },
  "Frontend": {
    "BaseUrl": "http://localhost:3000"
  },
  "Branding": {
    "SourceUrl": "https://github.com/htos/iab-connect"
  },
  "DocumentStorage": {
    "ServiceUrl": "",
    "AccessKey": "",
    "SecretKey": "",
    "BucketName": "iabconnect-documents",
    "UseHttps": true
  },
  "Hangfire": {
    "DashboardPath": "/hangfire"
  },
  "RateLimiting": {
    "_comment": "REQ-088 AC-4 / E14-S4: rate-limiting baseline. Anonymous 100/min/IP; authenticated 600/min/user; strict-identity policy 10/min (session-revocation + admin MFA reset). Healthcheck endpoints exempted via .DisableRateLimiting() chains. See docs/14_beta_railway_setup.md Section 23.",
    "AnonymousPermitLimit": 100,
    "AuthenticatedPermitLimit": 600,
    "StrictPermitLimit": 10,
    "WindowSeconds": 60
  },
  "Features": {
    "EInvoiceExport": true
  },
  "Smtp": {
    "Host": "",
    "Port": 587,
    "EnableSsl": true,
    "Username": null,
    "Password": null,
    "FromEmail": "noreply@example.org",
    "FromName": "Your Organization"
  },
  "InvoiceSettings": {
    "OrganizationName": "Your Organization",
    "OrganizationAddress": "Musterstrasse 1, 8000 Zürich",
    "OrganizationEmail": "info@example.org",
    "PaymentInstructions": "Please transfer the amount to our bank account.",
    "Currency": "CHF",
    "DefaultPaymentTermDays": 30
  }
}
